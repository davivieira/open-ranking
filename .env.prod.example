# Optional. If absent, prod uses: postgres/postgres, admin@open-ranking.com / admin123
# For Oracle Cloud: copy to .env.prod and set real secrets.
# Do not commit .env.prod to git.

POSTGRES_DB=open_ranking_prod
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-prod-password

JWT_SECRET_KEY=change-me-in-prod-use-long-random-string

INITIAL_ADMIN_EMAIL=admin@yourdomain.com
INITIAL_ADMIN_PASSWORD=change-this-admin-password
